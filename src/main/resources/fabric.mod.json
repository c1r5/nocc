{
	"schemaVersion": 1,
	"id": "nocc",
	"version": "${version}",
	"name": "NOCC ${version} (Fabric API ${fabric_api_version})",
	"description": "Nether and Overworld coordinate converter with HUD overlay and commands.",
	"authors": [
		"Me!"
	],
	"contact": {
		"homepage": "https://fabricmc.net/",
		"sources": "https://github.com/FabricMC/fabric-example-mod"
	},
	"license": "CC0-1.0",
	"icon": "assets/nocc/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			"dev.c1r5.nocc.entrypoints.Nocc"
		],
		"fabric-datagen": [
			"dev.c1r5.nocc.entrypoints.NoccDataGenerator"
		]
	},
	"mixins": [
		"nocc.mixins.json"
	],
	"depends": {
		"fabricloader": ">=0.19.3",
		"minecraft": "~26.1.2",
		"java": ">=25",
		"fabric-api": "*"
	}
}
